# theme
theme = catppuccin-mocha

# icon - Can be changed in the future
macos-icon = custom-style
macos-icon-frame = beige
macos-icon-ghost-color = #000000
macos-icon-screen-color = #ffffff

# ui
background-opacity=0.65
background-blur-radius = 25

# font settings
font-family = JetBrains Mono
font-style-bold = JetBrains Mono Bold
font-style-italic = JetBrains Mono Italic
font-style-bold-italic = JetBrains Mono Bold Italic
font-size = 14

# cursor settings
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

# macos title bar settings
macos-titlebar-style = tabs
macos-option-as-alt = true

# auto update settings
auto-update = download
auto-update-channel = stable

# extras
shell-integration-features = true
copy-on-select = clipboard
focus-follows-mouse = true
link-url = true

# window controls
confirm-close-surface = true
window-title-font-family = JetBrains Mono
window-decoration = false
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true
window-save-state = always


# custom keybindingsVictorMono NFM Italic
keybind = super+r=reload_config
keybind = super+i=inspector:toggle
keybind = super+f=toggle_fullscreen
keybind = super+left=previous_tab
keybind = super+right=next_tab

# quick terminal (global keybinding)
keybind = global:super+grave_accent=toggle_quick_terminal
quick-terminal-position = bottom
quick-terminal-autohide = true

# tmux-like prefix controlled keybindings
keybind = super+b>x=close_surface
keybind = super+b>c=new_tab
keybind = super+b>n=new_window
keybind = super+b>f=toggle_fullscreen


