# Core navigation — used constantly
alias tvf='tv files'           # browse files
alias tvd='tv dirs'            # browse directories
alias tvz='tv zoxide'          # jump to frecent dirs
alias tvt='tv text'            # ripgrep across files

# Git — you'll live in these
alias tvgb='tv git-branch'     # checkout branches
alias tvgl='tv git-log'        # browse commits
alias tvgd='tv git-diff'       # staged/unstaged diffs
alias tvgs='tv git-stash'      # stash browser
alias tvgr='tv git-repos'      # jump between repos

# Dotfiles & env
alias tvdot='tv dotfiles'      # edit config files
alias tve='tv env'             # inspect env vars
alias tval='tv zsh-alias'

# Docker (if you use it)
alias tvdc='tv docker-containers'
alias tvdi='tv docker-images'

# GitHub (if you use gh cli)
alias tvpr='tv gh-prs'
alias tvgi='tv gh-issues'

# Misc utilities
alias tvp='tv procs'           # process manager
alias tvss='tv ssh-hosts'      # ssh into hosts
alias tvman='tv man-pages'     # browse man pages
alias tvtodo='tv todo-comments' # find TODOs in codebase

# K8s 
alias tvkc='tv k8s-contexts'       # switch contexts

# zellij
alias tvzj='tv zellij-sessions'   # switch zellij sessions
